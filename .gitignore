# === COMMIT TẤT CẢ học liệu (PDF qua LFS, MD bình thường) ===
# subjects/*/lectures/{pdf,md}/*  ← KHÔNG ignore, commit cả
# subjects/*/exercises/{pdf,md}/* ← KHÔNG ignore, commit cả
# subjects/*/solutions/*          ← KHÔNG ignore, commit cả
# subjects/*/extensions/*         ← KHÔNG ignore, commit cả

# === IGNORE ===

# Logs
logs/*
!logs/.gitkeep

# Outputs có thể tái sinh
outputs/*
!outputs/.gitkeep

# IDE
# .vscode/  ← KHÔNG ignore vì muốn share settings.json
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Dữ liệu nhạy cảm
*.local
secrets/

# Copilot cache (nếu có)
.copilot/

# === Python (tools/pdf_extract) ===
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.smoke_test/
tools/pdf_extract/.smoke_test/

# Quy ước assets/: COMMIT cùng MD (giống policy PDF qua LFS — cần reproducibility
# khi clone trên máy khác chưa cài Python). Mỗi PDF convert tạo subjects/*/{lectures,exercises}/md/assets/
# nhỏ (PNG nén). Nếu repo size phình quá, xét lại bằng `git lfs migrate import --include="**/assets/*.png"`.
